# =============================================================================
# TERRAFORM TFVARS EXAMPLE - STAGING ENVIRONMENT
# =============================================================================
# Copie este arquivo para terraform.tfvars e preencha os valores.
#   cp terraform.tfvars.example terraform.tfvars
#
# ATENÇÃO: O arquivo terraform.tfvars está no .gitignore — NUNCA comitar!
# =============================================================================

project_name = "meu-projeto"
environment  = "staging"
location     = "eastus"

tags = {
  Owner      = "time-devops@empresa.com"
  CostCenter = "engineering"
}

vnet_address_space = ["10.1.0.0/16"]

subnets = {
  "compute" = {
    address_prefixes = ["10.1.1.0/24"]
  }
  "database" = {
    address_prefixes = ["10.1.2.0/24"]
  }
  "aks" = {
    address_prefixes = ["10.1.3.0/24"]
  }
}
