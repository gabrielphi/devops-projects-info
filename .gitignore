# Terraform
# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data, such as
# password, private keys, and other secrets. These should not be part of version 
# control as they are data based configuration files.
*.tfvars
*.tfvars.json

# Ignore override files as they are usually used to override resources locally and so
# are not checked in
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore .terraform.lock.hcl (optional, but often ignored in some workflows)
# .terraform.lock.hcl

# Ansible
*.retry

# Kubernetes & Helm
.kube/
kubeconfig
*.kubeconfig
.helm/

# Environment variables & Secrets
.env
.env.*
secrets.yaml
secrets.yml
*.secret
*.secrets
*password*
*credential*
*.pem
*.key

# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
ENV/

# OS
.DS_Store
Thumbs.db
desktop.ini

# IDEs
.vscode/
.idea/
*.swp
*.swo
.project
.settings/
.classpath
